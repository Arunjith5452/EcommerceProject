                <div class="footer__widget" style="display: flex; flex-direction: column; align-items: center;">
                    <h6 style="color: #ffffff; font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px;">Newsletter</h6>
