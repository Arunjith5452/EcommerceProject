<!-- Modern Dark Footer -->
<footer class="footer" style="background: #111111; color: #b7b7b7; padding: 40px 0 20px 0; margin-top: 0; width: 100%; position: relative; overflow: hidden; text-align: center;">
    <div class="container">
        <div class="row justify-content-center">
            <!-- Brand Section -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="footer__about" style="display: flex; flex-direction: column; align-items: center;">
                    <div class="footer__logo" style="margin-bottom: 15px;">
                        <h2 style="color: #ffffff; font-weight: 800; letter-spacing: 1px; font-family: 'Playfair Display', serif; margin: 0; font-size: 28px;">Fashion<span style="color: #e53637;">Kart</span></h2>
                    </div>
                    <p style="line-height: 1.6; font-size: 14px; max-width: 250px;">The premium destination for fashion with an uncompromising approach to quality and style.</p>
                    <div style="display: flex; gap: 15px; margin-top: 15px; justify-content: center;">
                        <a href="#" style="color: #fff; font-size: 18px; transition: color 0.3s;"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" style="color: #fff; font-size: 18px; transition: color 0.3s;"><i class="fab fa-twitter"></i></a>
                        <a href="#" style="color: #fff; font-size: 18px; transition: color 0.3s;"><i class="fab fa-instagram"></i></a>
                        <a href="#" style="color: #fff; font-size: 18px; transition: color 0.3s;"><i class="fab fa-pinterest"></i></a>
                    </div>
                </div>
            </div>

            <!-- Links Sections -->
            <div class="col-lg-2 col-md-3 mb-4">
                <div class="footer__widget">
                    <h6 style="color: #ffffff; font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px;">Shopping</h6>
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        <li style="margin-bottom: 10px;"><a href="/shop" style="color: #b7b7b7; transition: color 0.3s; text-decoration: none; font-size: 14px;">Clothing Store</a></li>
                        <li style="margin-bottom: 10px;"><a href="/shop" style="color: #b7b7b7; transition: color 0.3s; text-decoration: none; font-size: 14px;">Trending Shoes</a></li>
                        <li style="margin-bottom: 10px;"><a href="/shop" style="color: #b7b7b7; transition: color 0.3s; text-decoration: none; font-size: 14px;">Accessories</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-2 col-md-3 mb-4">
                <div class="footer__widget">
                    <h6 style="color: #ffffff; font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px;">Account</h6>
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        <li style="margin-bottom: 10px;"><a href="/userProfile" style="color: #b7b7b7; transition: color 0.3s; text-decoration: none; font-size: 14px;">My Profile</a></li>
                        <li style="margin-bottom: 10px;"><a href="/userProfile?tab=orders" style="color: #b7b7b7; transition: color 0.3s; text-decoration: none; font-size: 14px;">Orders</a></li>
                        <li style="margin-bottom: 10px;"><a href="/wishlist" style="color: #b7b7b7; transition: color 0.3s; text-decoration: none; font-size: 14px;">Wishlist</a></li>
                    </ul>
                </div>
            </div>

            <!-- Newsletter Section -->
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="footer__widget" style="display: flex; flex-direction: column; align-items: center;">
                    <h6 style="color: #ffffff; font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px;">Newsletter</h6>
                    <p style="margin-bottom: 15px; font-size: 14px;">Get updates on new arrivals & sales!</p>
                    <form action="#" style="position: relative; background: #222; border-radius: 4px; padding: 5px; width: 100%; max-width: 250px;">
                        <input type="text" placeholder="Your email" style="width: 100%; border: none; background: transparent; color: #fff; padding: 10px 15px; font-size: 14px;">
                        <button type="button" style="position: absolute; right: 5px; top: 50%; transform: translateY(-50%); border: none; background: var(--primary); color: #fff; height: 35px; width: 45px; border-radius: 4px; cursor: pointer;"><i class="fas fa-paper-plane"></i></button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Copyright -->
        <div class="row">
            <div class="col-lg-12" style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px;">
                <p style="margin: 0; color: #666; font-size: 13px;">Copyright © 2026 FashionKart. All rights reserved.</p>
            </div>
        </div>
    </div>
</footer>

<!-- JS Plugins -->
<script src="/js/jquery-3.3.1.min.js"></script>
<script src="/js/bootstrap.min.js"></script>
<script src="/js/jquery.nice-select.min.js"></script>
<script src="/js/jquery.nicescroll.min.js"></script>
<script src="/js/jquery.magnific-popup.min.js"></script>
<script src="/js/jquery.countdown.min.js"></script>
<script src="/js/jquery.slicknav.js"></script>
<script src="/js/mixitup.min.js"></script>
<script src="/js/owl.carousel.min.js"></script>
<script src="/js/main.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const currentPath = window.location.pathname;
        const navItems = { '/': '.nav-item-home', '/shop': '.nav-item-shop', '/about': '.nav-item-about' };
        Object.keys(navItems).forEach(path => {
            const el = document.querySelector(navItems[path]);
            if (el) el.classList.remove('active');
        });
        if (navItems[currentPath]) {
            const activeEl = document.querySelector(navItems[currentPath]);
            if (activeEl) activeEl.classList.add('active');
        }
    });

    document.addEventListener('DOMContentLoaded', function () {
        var isNewUser = false;
        <% if (typeof isNewUser !== 'undefined') { %> isNewUser = <%= isNewUser %>; <% } %>
        if (isNewUser) {
            Swal.fire({
                title: 'Welcome to FashionKart!',
                text: 'Enjoy your shopping experience with us.',
                icon: 'success',
                confirmButtonText: 'Let\'s Shop!'
            }).then(() => { fetch('/remove-new-user-flag'); });
        }
    });
</script>