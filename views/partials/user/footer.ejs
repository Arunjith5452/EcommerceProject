                    <ul style="list-style: none; padding: 0; margin: 0;">
                        <li style="margin-bottom: 10px;"><a href="/userProfile" style="color: #b7b7b7; transition: color 0.3s; text-decoration: none; font-size: 14px;">My Profile</a></li>
                        <li style="margin-bottom: 10px;"><a href="/userProfile?tab=orders" style="color: #b7b7b7; transition: color 0.3s; text-decoration: none; font-size: 14px;">Orders</a></li>
                        <li style="margin-bottom: 10px;"><a href="/wishlist" style="color: #b7b7b7; transition: color 0.3s; text-decoration: none; font-size: 14px;">Wishlist</a></li>
                    </ul>
