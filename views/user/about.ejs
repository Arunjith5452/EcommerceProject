        color: #111;
        margin-bottom: 30px;
    }
    .about-story-section {
        padding: 80px 0;
    }
    .story-content {
        font-size: 18px;
        line-height: 1.8;
        color: #555;
    }
    .highlight-strip {
        background: #111;
        color: #fff;
        padding: 60px 0;
        margin: 40px 0;
    }
    .stat-box h3 {
        font-size: 40px;
        font-weight: 800;
        color: #e53637;
        margin-bottom: 10px;
    }
    .stat-box p {
        font-size: 14px;
        text-transform: uppercase;
