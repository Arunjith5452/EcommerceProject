<%- include("../../views/partials/user/header") %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<style>
    @import url('https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@300;400;600;700;800;900&family=Playfair+Display:wght@700;900&display=swap');

    :root {
        --primary: #e53637;
        --accent: #ff8e8f; /* Matching the pinkish-red in user image */
        --dark: #111111;
        --light-gray: #f3f3f3;
        --body-text: #666666;
        --border: #e1e1e1;
    }

    body {
        font-family: 'Nunito Sans', sans-serif;
        color: var(--dark);
        background: #fff;
    }

    .product-details-wrap {
        padding: 60px 0;
    }

    /* Minimalist Breadcrumbs */
    .breadcrumb-row {
        margin-bottom: 30px;
        font-size: 13px;
        color: #999;
    }

    .breadcrumb-row a {
        color: #999;
        text-decoration: none;
        transition: 0.3s;
    }

    .breadcrumb-row a:hover { color: var(--primary); }

    /* Layout */
    .product-main-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 50px;
        margin-bottom: 80px;
    }

    /* Gallery - Image Left / Below Gallery */
    .gallery-column {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .main-img-view {
        width: 100%;
        height: auto;
        border-radius: 4px;
        overflow: hidden;
        background: #f9f9f9;
        position: relative;
        cursor: zoom-in;
    }

    .main-img-view img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.2s ease-out;
    }

    .thumb-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .thumb-item {
        border-radius: 4px;
        overflow: hidden;
        cursor: pointer;
        border: 2px solid transparent;
        transition: 0.3s;
    }

    .thumb-item.active { border-color: var(--primary); }
    .thumb-item img { width: 100%; height: 100%; object-fit: cover; }

    /* Info Column */
    .info-column {
        padding-top: 10px;
    }

    .product-cat {
        font-size: 14px;
        color: #999;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .product-title {
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 20px;
        color: var(--dark);
        letter-spacing: -0.5px;
    }

    .price-wrap {
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .price-main { font-size: 28px; font-weight: 800; color: var(--dark); }
    .price-old { font-size: 20px; color: #999; text-decoration: line-through; }
    .shipping-info { font-size: 14px; color: #999; font-weight: 500; }

    .desc-text {
        font-size: 15px;
        color: var(--body-text);
        line-height: 25px;
        margin-bottom: 35px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 30px;
    }

    /* Selections */
    .selection-label {
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        color: #999;
        margin-bottom: 15px;
        display: block;
    }

    .size-boxes {
        display: flex;
        gap: 10px;
        margin-bottom: 30px;
    }

    .size-box {
        width: 45px;
        height: 45px;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
        border-radius: 2px;
    }

    .size-box:hover:not(.disabled) { border-color: var(--dark); }
    .size-box.active { background: var(--dark); color: #fff; border-color: var(--dark); }
    .size-box.disabled { opacity: 0.3; cursor: not-allowed; text-decoration: line-through; background: #fafafa; }

    /* Actions */
    .action-row {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid var(--border);
        margin-bottom: 30px;
    }

    .qty-wrap {
        display: flex;
        align-items: center;
        border: 1px solid var(--border);
        height: 48px;
        border-radius: 2px;
    }

    .qty-btn {
        width: 40px;
        border: none;
        background: none;
        cursor: pointer;
        font-size: 18px;
        color: #999;
    }

    .qty-val {
        width: 40px;
        text-align: center;
        font-weight: 700;
        color: var(--dark);
    }

    .add-btn {
        background: var(--accent);
        color: #fff;
        border: none;
        height: 48px;
        padding: 0 40px;
        font-weight: 800;
        font-size: 13px;
        text-transform: uppercase;
        cursor: pointer;
        transition: 0.3s;
        border-radius: 2px;
        letter-spacing: 1px;
    }

    .add-btn:hover { background: var(--primary); }

    /* Meta */
    .meta-item { font-size: 13px; color: #999; margin-bottom: 10px; }
    .meta-item strong { color: var(--dark); font-weight: 700; margin-right: 5px; }

    /* Trust List */
    .trust-checklist {
        margin-top: 30px;
        list-style: none;
        padding: 0;
    }

    .trust-checklist li {
        font-size: 14px;
        font-weight: 700;
        color: var(--dark);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .trust-checklist li i { color: #222; font-size: 16px; }

    /* Checkout Area */


    /* Related Section */
    .related-title {
        font-size: 36px;
        font-weight: 900;
        text-align: center;
        margin-bottom: 50px;
        position: relative;
    }

    .related-title::after {
        content: '';
        position: absolute;
        bottom: -15px;
        left: 50%;
        transform: translateX(-50%);
        width: 80px;
        height: 4px;
        background: var(--dark);
    }

    .related-card { margin-bottom: 40px; }
    .related-img { height: 350px; border-radius: 4px; overflow: hidden; margin-bottom: 20px; background: #f9f9f9; }
    .related-img img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
    .related-card:hover .related-img img { transform: scale(1.05); }

    .related-info { text-align: center; }
    .related-info h6 { font-size: 16px; font-weight: 800; margin-bottom: 5px; }
    .related-info p { color: var(--primary); font-weight: 800; font-size: 18px; }

    @media (max-width: 768px) {
        .product-main-row { grid-template-columns: 1fr; }
        .add-btn { flex: 1; }
    }
</style>

<div class="container product-details-wrap">
    <!-- Breadcrumbs -->
    <div class="breadcrumb-row">
        <a href="/">Home</a> / <a href="/shop">Shop</a> / <a href="/filter?category=<%= category._id %>"><%= category.name %></a> / <span><%= product.productName %></span>
    </div>

    <!-- Main Content -->
    <div class="product-main-row">
        <!-- Gallery -->
        <div class="gallery-column">
            <div class="main-img-view" id="mainZoom">
                <img id="mainImage" src="/uploads/product-images/<%= product.productImage[0] %>" alt="">
            </div>
            <div class="thumb-row">
                <% for(let i=0; i<product.productImage.length; i++) { %>
                    <div class="thumb-item <%= i === 0 ? 'active' : '' %>" onclick="switchImage(this, '/uploads/product-images/<%= product.productImage[i] %>')">
                        <img src="/uploads/product-images/<%= product.productImage[i] %>" alt="">
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Info -->
        <div class="info-column">
            <div class="product-cat"><%= category.name %></div>
            <h1 class="product-title"><%= product.productName %></h1>

            <div class="price-wrap">
                <span class="price-main">₹<%= product.salePrice.toLocaleString('en-IN') %></span>
                <% if(product.regularPrice > product.salePrice) { %>
                    <span class="price-old">₹<%= product.regularPrice.toLocaleString('en-IN') %></span>
                <% } %>
                <span class="shipping-info">& Free Shipping</span>
            </div>

            <div class="desc-text">
                <%= product.description %>
            </div>

            <div class="selection-area">
                <span class="selection-label">Size</span>
                <div class="size-boxes">
                    <% product.sizeVariants.forEach(variant => { %>
                        <div class="size-box <%= variant.quantity === 0 ? 'disabled' : '' %>" 
                             onclick="selectSize(this, '<%= variant.size %>', <%= variant.quantity %>)">
                            <%= variant.size %>
                        </div>
                    <% }); %>
                </div>
                <!-- Size Stock Feedback -->
                <p id="stock-feedback" style="margin-top: -20px; margin-bottom: 25px; font-size: 13px; font-weight: 700; color: #2ecc71;"></p>
            </div>

            <div class="action-row">
                <div class="qty-wrap">
                    <button class="qty-btn" onclick="adjustQty(-1)">-</button>
                    <div class="qty-val" id="qtyDisplay">1</div>
                    <button class="qty-btn" onclick="adjustQty(1)">+</button>
                </div>
                <button class="add-btn" onclick="addToCart('<%= product._id %>')">Add to Cart</button>
            </div>

            <div class="product-meta-info">
                <div class="meta-item"><strong>SKU:</strong> FK-<%= product._id.toString().slice(-8).toUpperCase() %></div>
                <div class="meta-item"><strong>Category:</strong> <%= category.name %></div>
            </div>

            <ul class="trust-checklist">
                <li><i class="far fa-check-circle"></i> Secure Razorpay SSL Encryption</li>
                <li><i class="far fa-check-circle"></i> Cash on Delivery Available</li>
                <li><i class="far fa-check-circle"></i> Wallet & UPI Support</li>
            </ul>


        </div>
    </div>

    <!-- Related Products -->
    <% if(relatedProduct && relatedProduct.length > 0) { %>
        <section class="related-products-section">
            <h2 class="related-title">Related products</h2>
            <div class="row">
                <% relatedProduct.forEach(item => { %>
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="related-card">
                            <a href="/productDetails/<%= item._id %>" style="text-decoration: none; color: inherit;">
                                <div class="related-img">
                                    <img src="/uploads/product-images/<%= item.productImage[0] %>" alt="">
                                </div>
                                <div class="related-info">
                                    <h6><%= item.productName %></h6>
                                    <p>₹<%= item.salePrice.toLocaleString('en-IN') %></p>
                                </div>
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>
    <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Gallery Switcher
    function switchImage(el, src) {
        document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        document.getElementById('mainImage').src = src;
    }

    // Smooth Zoom
    const zoomContainer = document.getElementById('mainZoom');
    const mainImage = document.getElementById('mainImage');

    zoomContainer.addEventListener('mousemove', (e) => {
        const x = e.clientX - zoomContainer.getBoundingClientRect().left;
        const y = e.clientY - zoomContainer.getBoundingClientRect().top;
        mainImage.style.transformOrigin = `${x}px ${y}px`;
        mainImage.style.transform = "scale(2)";
    });

    zoomContainer.addEventListener('mouseleave', () => {
        mainImage.style.transformOrigin = "center center";
        mainImage.style.transform = "scale(1)";
    });

    // Selection & Cart
    let activeSize = null;
    let availStock = 0;
    let orderQty = 1;

    function selectSize(el, size, stock) {
        if(stock === 0) return;
        document.querySelectorAll('.size-box').forEach(b => b.classList.remove('active'));
        el.classList.add('active');
        activeSize = size;
        availStock = Math.min(stock, 5);
        orderQty = 1;
        document.getElementById('qtyDisplay').innerText = orderQty;
        document.getElementById('stock-feedback').innerHTML = `<i class="fa fa-info-circle"></i> Low Stock: ${stock} units left in size ${size}`;
    }

    function adjustQty(n) {
        if(!activeSize) {
            Swal.fire({ title: 'Note', text: 'Select a size first', icon: 'info' });
            return;
        }
        let v = orderQty + n;
        if(v >= 1 && v <= availStock) {
            orderQty = v;
            document.getElementById('qtyDisplay').innerText = orderQty;
        }
    }

    function addToCart(pid) {
        if(!activeSize) {
            Swal.fire({ title: 'Required', text: 'Pick a size', icon: 'error' });
            return;
        }
        fetch("/addToCart", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ productId: pid, size: activeSize, quantity: orderQty })
        })
        .then(res => res.json())
        .then(data => {
            if(data.success) {
                Swal.fire({ title: 'Added!', text: 'Saved to bag', icon: 'success' });
                if (typeof updateHeaderCounts === 'function') updateHeaderCounts();
            } else {
                Swal.fire({ title: 'Error', text: data.message, icon: 'error' });
            }
        });
    }
</script>

<%- include("../../views/partials/user/footer") %>