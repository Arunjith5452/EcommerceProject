<%-include("../../views/partials/user/header")%>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700;900&display=swap');

    :root {
        --primary: #e53637;
        --dark: #111111;
        --light: #f3f2ee;
        --gray: #707070;
        --border: #ebebeb;
        --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: var(--dark);
    }

    /* Breadcrumbs Section */
    .breadcrumb-section {
        background: var(--light);
        padding: 40px 0;
        margin-bottom: 50px;
    }

    .breadcrumb__text h2 {
        font-family: 'Playfair Display', serif;
        font-size: 36px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .breadcrumb__links a {
        font-size: 14px;
        color: var(--dark);
        text-decoration: none;
        margin-right: 10px;
        font-weight: 600;
    }

    .breadcrumb__links span {
        font-size: 14px;
        color: var(--gray);
    }

    /* Shop Layout */
    .shop-container {
        padding-bottom: 100px;
    }

    /* Modern Sidebar */
    .shop__sidebar {
        padding-right: 20px;
    }

    .sidebar__widget {
        margin-bottom: 40px;
    }

    .sidebar__title {
        font-size: 16px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 25px;
        position: relative;
    }

    .sidebar__title:after {
        content: '';
        position: absolute;
        width: 30px;
        height: 2px;
        background: var(--primary);
        left: 0;
        bottom: -8px;
    }

    .sidebar__categories ul, .sidebar__price ul {
        list-style: none;
        padding: 0;
    }

    .sidebar__categories ul li, .sidebar__price ul li {
        margin-bottom: 12px;
    }

    .sidebar__link {
        font-size: 15px;
        color: var(--gray);
        text-decoration: none;
        transition: var(--transition);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .sidebar__link:hover, .sidebar__link.active {
        color: var(--primary);
        font-weight: 700;
        transform: translateX(5px);
    }

    /* Shop Topbar */
    .shop__product__option {
        margin-bottom: 40px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 20px;
    }

    .shop__product__option__left p {
        font-size: 14px;
        color: var(--gray);
        margin-bottom: 0;
    }

    .shop__product__option__right {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 20px;
    }

    .shop__product__option__right select {
        border: none;
        font-size: 14px;
        font-weight: 700;
        color: var(--dark);
        outline: none;
        background: transparent;
        cursor: pointer;
    }

    /* Premium Product Card */
    .product__item {
        margin-bottom: 35px;
        transition: var(--transition);
    }

    .product__item__pic {
        height: 320px;
        position: relative;
        overflow: hidden;
        border-radius: 12px;
    }

    .product__item__pic img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .product__item:hover .product__item__pic img {
        transform: scale(1.1);
    }

    .product__label {
        position: absolute;
        left: 0;
        top: 20px;
        background: #ffffff;
        color: var(--dark);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        padding: 4px 12px;
        letter-spacing: 1px;
        z-index: 2;
    }

    .product__hover {
        position: absolute;
        right: -50px;
        top: 20px;
        list-style: none;
        transition: var(--transition);
    }

    .product__item:hover .product__hover {
        right: 20px;
    }

    .product__hover li {
        margin-bottom: 10px;
    }

    .product__hover li button, .product__hover li a {
        background: #ffffff;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        border: none;
        cursor: pointer;
        transition: var(--transition);
        color: var(--dark);
        font-size: 16px;
    }

    .product__hover li button:hover, .product__hover li a:hover {
        background: var(--primary);
        color: #ffffff;
    }

    .product__item__text {
        padding-top: 25px;
        text-align: center;
    }

    .product__item__text h6 {
        font-size: 15px;
        font-weight: 700;
        color: var(--dark);
        margin-bottom: 10px;
        transition: var(--transition);
    }

    .product__item:hover .product__item__text h6 {
        color: var(--primary);
    }

    .rating {
        margin-bottom: 10px;
    }

    .rating i {
        color: #f7941d;
        font-size: 12px;
    }

    .price-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
    }

    .price-container h5 {
        font-size: 18px;
        font-weight: 800;
        color: var(--dark);
        margin: 0;
    }

    .price-container span {
        font-size: 14px;
        color: var(--gray);
        text-decoration: line-through;
        font-weight: 500;
    }

    /* Advanced Pagination */
    .product__pagination {
        padding-top: 25px;
        display: flex;
        justify-content: center;
        gap: 10px;
    }

    .product__pagination a {
        display: inline-block;
        width: 40px;
        height: 40px;
        line-height: 38px;
        text-align: center;
        font-size: 14px;
        font-weight: 700;
        color: var(--dark);
        border: 1px solid var(--border);
        border-radius: 50%;
        text-decoration: none;
        transition: var(--transition);
    }

    .product__pagination a:hover, .product__pagination a.active {
        background: var(--dark);
        color: #fff;
        border-color: var(--dark);
    }

    /* Search Bar Refinement */
    .shop__sidebar__search {
        position: relative;
        margin-bottom: 45px;
    }

    .shop__sidebar__search input {
        width: 100%;
        height: 45px;
        border: 1px solid var(--border);
        border-radius: 30px;
        padding-left: 20px;
        padding-right: 50px;
        font-size: 14px;
        outline: none;
        transition: var(--transition);
    }

    .shop__sidebar__search input:focus {
        border-color: var(--primary);
    }

    .shop__sidebar__search button {
        position: absolute;
        right: 5px;
        top: 5px;
        height: 35px;
        width: 35px;
        border-radius: 50%;
        background: var(--primary);
        border: none;
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
        padding: 0;
    }

    .shop__sidebar__search button i {
        font-size: 14px;
        margin: 0;
        padding: 0;
    }

    .shop__sidebar__search button:hover {
        background: var(--dark);
        transform: scale(1.05);
    }

    /* No Products Found */
    .no-results {
        text-align: center;
        padding: 80px 0;
    }

    .no-results i {
        font-size: 64px;
        color: #ddd;
        margin-bottom: 25px;
    }

    @media (max-width: 767px) {
        .shop__product__option__right { justify-content: flex-start; margin-top: 20px; }
        .product__item__pic { height: 250px; }
    }
</style>

<!-- Breadcrumb Section -->
<section class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb__text">
                    <h2>Shop Your Style</h2>
                    <div class="breadcrumb__links">
                        <a href="/">Home</a>
                        <i class="fa fa-angle-right"></i>
                        <span>Shop</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Shop Section -->
<section class="shop-container">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <aside class="col-lg-3">
                <div class="shop__sidebar">
                    <div class="shop__sidebar__search">
                        <form action="/search" method="POST">
                            <input type="text" name="query" placeholder="Search items, styles..." value="<%= searchQuery || '' %>">
                            <button type="submit"><i class="fa fa-search"></i></button>
                        </form>
                    </div>
                    
                    <div class="sidebar__widget">
                        <h4 class="sidebar__title">Categories</h4>
                        <div class="sidebar__categories">
                            <ul>
                                <li>
                                    <a href="/shop" class="sidebar__link <%= !selectedCategory ? 'active' : '' %>">
                                        All Collections <span>(<%= totalProducts || 'All' %>)</span>
                                    </a>
                                </li>
                                <% for(let i=0; i<category.length; i++) { %>
                                    <li>
                                        <a href="/filter?category=<%= category[i]._id %>" 
                                           class="sidebar__link <%= selectedCategory && selectedCategory.toString() === category[i]._id.toString() ? 'active' : '' %>">
                                            <%= category[i].name %>
                                        </a>
                                    </li>
                                <% } %>
                            </ul>
                        </div>
                    </div>

                    <div class="sidebar__widget">
                        <h4 class="sidebar__title">Filter Price</h4>
                        <div class="sidebar__price">
                            <ul>
                                <li><a href="/filterPrice?gt=0&lt=500" class="sidebar__link">₹0.00 - ₹500.00</a></li>
                                <li><a href="/filterPrice?gt=500&lt=1000" class="sidebar__link">₹500.00 - ₹1000.00</a></li>
                                <li><a href="/filterPrice?gt=1000&lt=1500" class="sidebar__link">₹1000.00 - ₹1500.00</a></li>
                                <li><a href="/filterPrice?gt=1500&lt=1000000" class="sidebar__link">₹1500.00 +</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Main Shop Content -->
            <div class="col-lg-9">
                <div class="shop__product__option">
                    <div class="row">
                        <div class="col-lg-6 col-md-6 col-sm-6">
                            <div class="shop__product__option__left">
                                <p>Showing <%= products.length %> results of <%= totalProducts || products.length %></p>
                            </div>
                        </div>
                        <div class="col-lg-6 col-md-6 col-sm-6">
                            <div class="shop__product__option__right">
                                <p>Sort by:</p>
                                <select onchange="sortProducts(this.value)">
                                    <option value="default" <%= selectedSort === 'default' ? 'selected' : '' %>>Newest Items</option>
                                    <option value="low" <%= selectedSort === 'low' ? 'selected' : '' %>>Price: Low to High</option>
                                    <option value="high" <%= selectedSort === 'high' ? 'selected' : '' %>>Price: High to Low</option>
                                    <option value="az" <%= selectedSort === 'az' ? 'selected' : '' %>>Name: A to Z</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <% if (products.length === 0) { %>
                    <div class="no-results">
                        <i class="fa fa-shopping-bag"></i>
                        <h3>We couldn't find any items matching your criteria</h3>
                        <p>Try resetting your filters or using broader search terms.</p>
                        <a href="/shop" class="primary-btn" style="background: var(--dark); border-radius: 30px; padding: 12px 35px; color: #fff; text-decoration: none;">Explore All Products</a>
                    </div>
                <% } else { %>
                    <div class="row">
                        <% for(let i=0; i<products.length; i++) { %>
                            <div class="col-lg-4 col-md-6 col-sm-6">
                                <div class="product__item">
                                    <div class="product__item__pic">
                                        <img src="/uploads/product-images/<%= products[i].productImage[0] %>" alt="<%= products[i].productName %>">
                                        <% if (products[i].totalOffer > 0) { %>
                                            <span class="product__label"><%= products[i].totalOffer %>% OFF</span>
                                        <% } %>
                                        <ul class="product__hover">
                                            <li><button onclick="addToWishlist('<%= products[i]._id %>')"><i class="fa fa-heart"></i></button></li>
                                            <li><a href="/productDetails/<%= products[i]._id %>"><i class="fa fa-expand"></i></a></li>
                                        </ul>
                                    </div>
                                    <div class="product__item__text">
                                        <h6><%= products[i].productName %></h6>
                                        <div class="price-container">
                                            <h5>₹<%= products[i].salePrice.toLocaleString('en-IN') %></h5>
                                            <% if (products[i].regularPrice > products[i].salePrice) { %>
                                                <span>₹<%= products[i].regularPrice.toLocaleString('en-IN') %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>
                <% } %>

                <div class="product__pagination">
                    <% if (currentPage > 1) { %>
                        <a href="?page=<%= currentPage - 1 %>&sort=<%= selectedSort %>"><i class="fa fa-angle-left"></i></a>
                    <% } %>
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a class="<%= currentPage === i ? 'active' : '' %>" href="?page=<%= i %>&sort=<%= selectedSort %>"><%= i %></a>
                    <% } %>
                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= currentPage + 1 %>&sort=<%= selectedSort %>"><i class="fa fa-angle-right"></i></a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.0/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
function addToWishlist(productId){
    fetch("/addToWishlist",{
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({productId:productId})
    })
    .then(res => res.json())
    .then(data => {
        Swal.fire({
            title: data.status ? 'Added!' : 'Info',
            text: data.status ? 'Product added to wishlist' : data.message,
            icon: data.status ? 'success' : 'info',
            timer: 1500,
            showConfirmButton: false
        });
    })
    .catch(() => {
        Swal.fire({title: 'Error', text: 'Something went wrong', icon: 'error'});
    });
}

function sortProducts(value) {
    let url = new URL(window.location.href);
    url.searchParams.set('sort', value);
    window.location.href = url.toString();
}
</script>
<%-include("../../views/partials/user/footer")%>