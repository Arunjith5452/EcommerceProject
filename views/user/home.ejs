<%-include("../../views/partials/user/header")%>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root {
            --primary-color: #e53637;
            --text-dark: #111111;
            --text-gray: #b7b7b7;
            --bg-light: #f3f2ee;
        }

        body {
            -webkit-font-smoothing: antialiased;
        }

        /* Enhanced Product Cards */
        .product-card {
            position: relative;
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(0,0,0,0.03);
            cursor: pointer;
        }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

        .product-img-wrap {
            position: relative;
            padding-top: 100%; 
            overflow: hidden;
            background-color: #f8f9fa;
        }

        .product-img {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        .product-card:hover .product-img {
            transform: translate(-50%, -50%) scale(1.08);
        }

        .wishlist-btn {
            position: absolute;
            top: 15px;
            right: 15px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(4px);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            cursor: pointer;
            z-index: 2;
            border: none;
            transition: all 0.3s ease;
        }

        .wishlist-btn:hover {
            background: var(--primary-color);
            transform: scale(1.1);
        }

        .wishlist-btn i {
            color: #b7b7b7;
            font-size: 18px;
            transition: all 0.3s ease;
        }

        .wishlist-btn:hover i {
            color: #ffffff;
        }

        .product-details {
            padding: 20px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .product-name {
            font-size: 16px;
            color: var(--text-dark);
            margin-bottom: 12px;
            font-weight: 600;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: color 0.3s;
        }

        .product-card:hover .product-name {
            color: var(--primary-color);
        }

        .product-price-container {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }

        .current-price {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-dark);
        }

        .original-price {
            font-size: 14px;
            text-decoration: line-through;
            color: var(--text-gray);
            font-weight: 500;
        }

        .discount-tag {
            background: rgba(229, 54, 55, 0.1);
            color: var(--primary-color);
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 700;
            margin-left: auto;
        }

        .product-delivery {
            color: #28a745;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* Banner & Hero Enhancements */
        .banner {
            padding-bottom: 50px;
        }

        .banner__item {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease;
            margin-bottom: 30px;
            background: #000; /* fall back if image doesn't load */
        }

        .banner__item:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.25);
        }

        .banner__item__pic img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            aspect-ratio: 4/3;
            display: block;
            transition: transform 0.6s ease;
        }

        .banner__item:hover .banner__item__pic img {
            transform: scale(1.05);
        }

        /* Sleek Gradient Overlay to make Text Pop */
        .banner__item::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0) 100%);
            pointer-events: none;
        }

        .banner__item__text {
            position: absolute;
            bottom: 30px;
            left: 30px;
            right: 30px;
            z-index: 2;
            text-align: left;
        }

        .banner__item__text h2 {
            color: #ffffff;
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 12px;
            line-height: 1.2;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
            letter-spacing: 0.5px;
        }

        .banner__item__text a {
            display: inline-block;
            color: #ffffff;
            font-size: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            border-bottom: 2px solid var(--primary-color);
            padding-bottom: 4px;
            transition: color 0.3s, border-color 0.3s;
            text-decoration: none;
        }

        .banner__item__text a:hover {
            color: var(--primary-color);
            border-color: #ffffff;
        }

        .hero__text h2 {
            text-transform: uppercase;
            letter-spacing: 2px;
            animation: fadeInDown 1s ease-out;
        }

        .hero__text p {
            animation: fadeIn 1.5s ease-out;
            opacity: 0.9;
        }

        .primary-btn {
            border-radius: 30px; /* makes it look like a sleek modern button */
            padding: 14px 30px;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(229, 54, 55, 0.4);
            font-weight: 700;
            font-size: 14px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .primary-btn:hover {
            box-shadow: 0 8px 25px rgba(229, 54, 55, 0.6);
            transform: translateY(-3px);
            background-color: #c92f2f;
            color: white;
        }

        /* Section Titles */
        .product.spad {
            padding-top: 50px;
            padding-bottom: 50px;
            background-color: #fcfcfc; /* subtle gray to remove pure white space */
        }

        .filter__controls {
            margin-bottom: 40px;
        }

        .filter__controls li {
            font-weight: 800;
            font-size: 32px;
            color: var(--text-dark);
            position: relative;
            padding-bottom: 18px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .filter__controls li:after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: var(--primary-color);
            border-radius: 2px;
            transition: width 0.3s;
        }

        .filter__controls li:hover:after {
            width: 120px;
        }

        @media (max-width: 768px) {
            .hero__items {
                height: 60vh !important;
            }
            .hero__text h2 {
                font-size: 28px !important;
                margin-bottom: 15px !important;
            }
            .hero__text p {
                font-size: 14px !important;
                margin-bottom: 20px !important;
            }
            .filter__controls li {
                font-size: 22px !important;
            }
        }
    </style>
    <section class="hero">
        <div class="hero__slider owl-carousel">
            <div class="hero__items set-bg" data-setbg="img/hero/hero-1.png" style="background-position: center; background-size: cover; height: 80vh;">
                <div class="container h-100">
                    <div class="row h-100 align-items-center">
                        <div class="col-xl-5 col-lg-7 col-md-8">
                            <div class="hero__text">
                                <h6 style="color: var(--primary-color); font-weight: 700; letter-spacing: 3px; margin-bottom: 15px;">SUMMER 2026</h6>
                                <h2 style="font-size: 54px; font-weight: 900; line-height: 1.1; margin-bottom: 25px; color: #111;">Elevate Your Wardrobe</h2>
                                <p style="font-size: 16px; color: #333; margin-bottom: 35px; max-width: 400px; line-height: 1.6;">Discover our latest collection of premium quality clothing designed for your everyday comfort and style.</p>
                                <a href="/shop" class="primary-btn">Shop now <i class="fas fa-arrow-right ml-2"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="hero__items set-bg" data-setbg="img/hero/hero-2.png" style="background-position: center; background-size: cover; height: 80vh;">
                <div class="container h-100">
                    <div class="row h-100 align-items-center">
                        <div class="col-xl-5 col-lg-7 col-md-8">
                            <div class="hero__text">
                                <h6 style="color: var(--primary-color); font-weight: 700; letter-spacing: 3px; margin-bottom: 15px;">LIMITED EDITION</h6>
                                <h2 style="font-size: 54px; font-weight: 900; line-height: 1.1; margin-bottom: 25px; color: #111;">The Signature Series</h2>
                                <p style="font-size: 16px; color: #333; margin-bottom: 35px; max-width: 400px; line-height: 1.6;">Handcrafted pieces that define modern elegance. Shop the exclusive limited-time collection today.</p>
                                <a href="/shop" class="primary-btn">Shop now <i class="fas fa-arrow-right ml-2"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <section class="banner spad" style="padding-top: 80px; padding-bottom: 40px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 col-md-4 col-sm-6">
                    <div class="banner__item">
                        <div class="banner__item__pic">
                            <img src="img/banner/banner-1.jpg" alt="Accessories">
                        </div>
                        <div class="banner__item__text">
                            <h2>Accessories</h2>
                            <a href="/shop">Shop now</a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-6">
                    <div class="banner__item">
                        <div class="banner__item__pic">
                            <img src="/uploads/product-images/product imagebrand.jpg" alt="Brand">
                        </div>
                        <div class="banner__item__text">
                            <h2>Branded Edit</h2>
                            <a href="/shop">Shop now</a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-6">
                    <div class="banner__item">
                        <div class="banner__item__pic">
                            <img src="/uploads/product-images/1736536482732-image-1736536482707-1.jpg" alt="Spring 2030">
                        </div>
                        <div class="banner__item__text">
                            <h2>Spring 2030</h2>
                            <a href="/shop">Shop now</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <section class="product spad">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <ul class="filter__controls text-center">
                        <li data-filter=".new-arrivals">Trending Now</li>
                    </ul>
                </div>
            </div>
            <div class="row product__filter">
                <%for(let i=0;i<products.length;i++){%>
                <div class="col-lg-3 col-md-4 col-12 col-sm-6 mb-4">
                    <div class="product-card" onclick="window.location.href='/productDetails/<%=products[i]._id%>'">
                        
                        <button class="wishlist-btn" onclick="event.stopPropagation(); addToWishlist('<%=products[i]._id%>')" title="Add to Wishlist">
                            <i class="fas fa-heart"></i>
                        </button>
                        
                        <div class="product-img-wrap">
                            <img class="product-img" 
                                 src="/uploads/product-images/<%=products[i].productImage[0]%>" 
                                 alt="<%=products[i].productName%>"
                                 onerror="this.src='/path-to-placeholder-image.jpg'">
                        </div>
                        
                        <div class="product-details">
                            <h3 class="product-name" title="<%=products[i].productName%>"><%=products[i].productName%></h3>
                            
                            <div class="product-price-container">
                                <span class="current-price">₹<%=products[i].salePrice.toLocaleString('en-IN')%></span>
                                <% if(products[i].regularPrice && products[i].regularPrice > products[i].salePrice) { %>
                                    <span class="original-price">
                                        ₹<%=products[i].regularPrice.toLocaleString('en-IN')%>
                                    </span>
                                    <% let discountPercentage = Math.round(((products[i].regularPrice - products[i].salePrice) / products[i].regularPrice) * 100); %>
                                    <% if (discountPercentage > 0) { %>
                                        <span class="discount-tag"><%=discountPercentage%>% OFF</span>
                                    <% } %>
                                <% } %>
                            </div>
                            
                            <div class="product-delivery">
                                <i class="fas fa-shipping-fast"></i> Free Delivery
                            </div>
                        </div>
                    </div>
                </div>
                <%}%>
            </div>
        </div>
    </section>

    <!-- Services Section (Clean White Theme) -->
    <section class="services spad" style="padding-top: 80px; padding-bottom: 80px; background: #ffffff;">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 col-md-4 col-sm-6">
                    <div class="services__item text-center">
                        <i class="fas fa-shield-alt mb-3" style="font-size: 32px; color: #333;"></i>
                        <h6 style="font-weight: 600; font-size: 18px; color: #1c3d5a; margin-bottom: 12px;">Secure checkout</h6>
                        <p style="font-size: 14px; color: #7f8c8d; line-height: 1.6; max-width: 280px; margin: 0 auto;">Shop with confidence using our encrypted payment system that protects your sensitive information.</p>
                    </div>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-6">
                    <div class="services__item text-center">
                        <i class="fas fa-shipping-fast mb-3" style="font-size: 32px; color: #333;"></i>
                        <h6 style="font-weight: 600; font-size: 18px; color: #1c3d5a; margin-bottom: 12px;">Free shipping</h6>
                        <p style="font-size: 14px; color: #7f8c8d; line-height: 1.6; max-width: 280px; margin: 0 auto;">Enjoy complimentary delivery on all orders, with no minimum purchase required.</p>
                    </div>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-6">
                    <div class="services__item text-center">
                        <i class="fas fa-undo mb-3" style="font-size: 32px; color: #333;"></i>
                        <h6 style="font-weight: 600; font-size: 18px; color: #1c3d5a; margin-bottom: 12px;">30 days return</h6>
                        <p style="font-size: 14px; color: #7f8c8d; line-height: 1.6; max-width: 280px; margin: 0 auto;">Not satisfied? Return any item within 30 days of purchase for a full refund or exchange.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
     
     function addToWishlist(productId){
        fetch("/addToWishlist",{
            method:"POST",
            headers:{"Content-Type":"application/json"},
            body:JSON.stringify({productId:productId})
        })
        .then((response)=>response.json())
        .then((data)=>{
            if(data.status){
                showToast('Added to wishlist!', 'success');
            }else{
                showToast(data.message || 'Already in wishlist', 'info');
            }
        })
        .catch((error)=>{
            showToast('Error adding product to wishlist', 'error');
        })
     }

    </script>

    <%-include("../../views/partials/user/footer")%>