                              body: JSON.stringify(Object.fromEntries(formData))
                            });

                            if (response.ok) {
                              const data = await response.json();
                              window.editModal.hide();
                              
                              // Update UI dynamically
                              const formDataObj = Object.fromEntries(formData);
                              const usernameHeader = document.querySelector('.card-body.text-center h5.mb-4');
                              if (usernameHeader) usernameHeader.textContent = formDataObj.username;
                              
                              const phoneText = document.querySelector('.text-muted.mb-2');
                              if (phoneText) phoneText.innerHTML = `<strong>Phone:</strong> ${formDataObj.mobile}`;
                              
                              showToast('Your profile has been updated successfully.', 'success');
